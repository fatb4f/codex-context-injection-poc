+#[test]
+fn context_injection_surfaces_hook_prompt_fragment_is_user_message_output() {
+    let item = build_hook_prompt_message(&[HookPromptFragment::from_single_hook(
+        "POC_SENTINEL_HOOK_HINT",
+        "hook-run-1",
+    )])
+    .expect("hook prompt message");
+
+    assert!(matches!(item, ResponseItem::Message { role, .. } if role == "user"));
+}
+
+#[test]
+fn context_injection_surfaces_json_tool_output_is_not_message() {
+    let function_item = FunctionToolOutput::from_text(
+        "POC_SENTINEL_JSON_TOOL_OUTPUT".to_string(),
+        Some(true),
+    )
+    .to_response_item(
+        "json-call-1",
+        &ToolPayload::Function {
+            arguments: "{}".to_string(),
+        },
+    );
+    assert!(matches!(function_item, ResponseInputItem::FunctionCallOutput { .. }));
+
+    let custom_item = FunctionToolOutput::from_text(
+        "POC_SENTINEL_JSON_TOOL_OUTPUT".to_string(),
+        Some(true),
+    )
+    .to_response_item(
+        "json-call-2",
+        &ToolPayload::Custom {
+            input: "{}".to_string(),
+        },
+    );
+    assert!(matches!(custom_item, ResponseInputItem::CustomToolCallOutput { .. }));
+}
+
+#[test]
+fn context_injection_surfaces_mcp_tool_output_is_function_call_output() {
+    let output = McpToolOutput {
+        result: CallToolResult {
+            content: vec![serde_json::json!({
+                "type": "text",
+                "text": "POC_SENTINEL_MCP_TOOL_OUTPUT",
